{
  "name": "bicak-satis",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/stop-dev.mjs && node scripts/prepare-dev-db.mjs && next dev",
    "dev:stop": "node scripts/stop-dev.mjs",
    "build": "node scripts/vercel-migrate.mjs && prisma generate && next build",
    "postinstall": "prisma generate && prisma generate --schema prisma/schema.sqlite.prisma",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate && prisma generate --schema prisma/schema.sqlite.prisma",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma migrate deploy && tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:docker": "docker compose up -d db"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^6.19.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.4.1",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
